{
  "manifest_version": 3,
  "name": "PixelSchema",
  "version": "1.0",
  "description": "Places a generic stencil over the canvas",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://pixelbattle.eventvoid.dev/*",
    "https://raw.githubusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://pixelbattle.eventvoid.dev/*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
